FROM ./phi-4-mini-reasoning-q5_k_m.gguf

# TEMPLATE explícito obrigatório: o GGUF não tem chat_template embutido nos metadados.
# Sem isso, Ollama usa {{ .Prompt }} (passthrough raw) e as role boundaries se perdem —
# reproduz o bug documentado em LESSONS_LEARNED.md Lição 1 (chatml corrompendo tokenização).
TEMPLATE """{{ if .System }}<|system|>
{{ .System }}<|end|>
{{ end }}{{ if .Prompt }}<|user|>
{{ .Prompt }}<|end|>
{{ end }}<|assistant|>
{{ .Response }}<|end|>
"""

PARAMETER num_ctx 8192
PARAMETER num_predict 512
PARAMETER temperature 0.1
